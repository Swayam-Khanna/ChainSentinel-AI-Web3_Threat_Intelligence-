# ─── Backend Config ──────────────────────────────────────────────────────────
PORT=4000
MONGODB_URI=mongodb+srv://<user>:<password>@cluster.mongodb.net/chainsentinel
SIMULATION_MODE=true

# ─── Blockchain Config ────────────────────────────────────────────────────────
# Get your WebSocket URL from Alchemy or Infura
ETH_WS_URL=wss://eth-mainnet.g.alchemy.com/v2/YOUR_API_KEY

# ─── Frontend Config ─────────────────────────────────────────────────────────
# Use http://localhost:4000 for local, or your deployed backend URL
VITE_API_URL=http://localhost:4000
VITE_WS_URL=ws://localhost:4000
