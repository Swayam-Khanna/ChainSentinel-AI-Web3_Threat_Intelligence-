# Ethereum RPC Provider (use Alchemy or Infura WebSocket URL)
# Get free key at: https://www.alchemy.com/
ETH_WS_URL=wss://eth-mainnet.g.alchemy.com/v2/YOUR_ALCHEMY_KEY

# Fallback: Use simulation mode (no real RPC needed)
SIMULATION_MODE=true

# Server Config
PORT=4000
FRONTEND_URL=http://localhost:5173

# Alert thresholds
GAS_SPIKE_MULTIPLIER=3
BURST_TX_THRESHOLD=5
BURST_WINDOW_MS=10000
